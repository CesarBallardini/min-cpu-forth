{
  "include": ["src", "tests"],
  "extraPaths": ["tests"],
  "exclude": ["**/__pycache__", ".venv"],
  "venvPath": ".",
  "venv": ".venv",
  "pythonVersion": "3.14",
  "typeCheckingMode": "standard",
  "reportUnusedImport": "error",
  "reportOptionalMemberAccess": "error",
  "reportIncompatibleMethodOverride": "error"
}
